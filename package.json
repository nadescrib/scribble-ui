{
  "name": "scribble-ui",
  "version": "1.3.0",
  "description": "Lightweight Material-inspired CSS framework",
  "main": "dist/scribble-ui.min.css",
  "style": "dist/scribble-ui.min.css",
  "scripts": {
    "dev": "browser-sync start --server . --index public/index.html --files \"public/*.html, src/**/*.css\"",
    "build": "postcss src/scribble-ui.css -o dist/scribble-ui.min.css"
  },
  "keywords": [
    "css",
    "framework",
    "material",
    "ui",
    "bootstrap"
  ],
  "author": "tony-tripulca",
  "license": "MIT",
  "devDependencies": {
    "browser-sync": "^3.0.4",
    "cssnano": "^7.1.3",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1"
  }
}
